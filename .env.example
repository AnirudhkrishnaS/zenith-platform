# ===========================================
# Zenith Platform – environment variables
# Copy this file to .env and set values.
# Do not commit .env to version control.
# ===========================================

# Database (used by user, store, order, delivery services)
DB_URL=jdbc:postgresql://localhost:5432/zenith_users
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (User Service – token signing)
# Use a long random string in production (min 32 characters)
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-32-chars
JWT_EXPIRATION_MS=900000

# Redis (Delivery Service, Notification Service)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: per-service DB names if you use a single Postgres instance
# DB_URL is typically overridden per service in application.properties
# Example for production:
# DB_URL=jdbc:postgresql://your-rds-host:5432/zenith_users
