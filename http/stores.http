@storeService = http://localhost:8082
@gateway = http://localhost:8080
@userId = 1
@userType = BUSINESS_OWNER
@storeId = 1
@productId = 1
@token =

GET {{storeService}}/api/stores

###

GET {{storeService}}/api/stores/{{storeId}}

###

GET {{storeService}}/api/stores/mine
X-User-Id: {{userId}}

###

POST {{storeService}}/api/stores
X-User-Id: {{userId}}
X-User-Type: {{userType}}
Content-Type: application/json

{
  "name": "My Coffee Shop",
  "address": "123 Main St",
  "phone": "+1234567890",
  "description": "Best coffee in town"
}

###

PUT {{storeService}}/api/stores/{{storeId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "name": "My Coffee Shop Updated",
  "address": "456 New St",
  "phone": "+9876543210"
}

###

GET {{storeService}}/api/stores/{{storeId}}/products

###

GET {{storeService}}/api/stores/{{storeId}}/products/{{productId}}

###

GET {{storeService}}/api/stores/{{storeId}}/products/sku/ESPRESSO-01

###

GET {{storeService}}/api/stores/{{storeId}}/products/upc/012345678905

###

# Two-level: 1) Create product (logical), 2) Add SKUs (sellable variants)
POST {{storeService}}/api/stores/{{storeId}}/products
X-User-Id: {{userId}}
X-User-Type: {{userType}}
Content-Type: application/json

{
  "name": "Espresso",
  "description": "Single shot"
}

###
# Add first SKU (e.g. size/variant) to product; use productId from create response
POST {{storeService}}/api/stores/{{storeId}}/products/{{productId}}/skus
X-User-Id: {{userId}}
X-User-Type: {{userType}}
Content-Type: application/json

{
  "sku": "ESPRESSO-01",
  "upc": "012345678905",
  "price": 2.50
}

###
# Add another SKU to same product (e.g. large size)
POST {{storeService}}/api/stores/{{storeId}}/products/{{productId}}/skus
X-User-Id: {{userId}}
X-User-Type: {{userType}}
Content-Type: application/json

{
  "sku": "ESPRESSO-02",
  "price": 3.50
}

###

PUT {{storeService}}/api/stores/{{storeId}}/products/{{productId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "name": "Espresso (updated)",
  "description": "Single or double shot"
}

###

# Delete product (cascades to all its SKUs)
DELETE {{storeService}}/api/stores/{{storeId}}/products/{{productId}}
X-User-Id: {{userId}}

###
# Or delete a single SKU (use skuId from list/get product response)
# DELETE {{storeService}}/api/stores/{{storeId}}/products/{{productId}}/skus/{{skuId}}
# X-User-Id: {{userId}}

###
GET {{gateway}}/api/stores
Authorization: Bearer {{token}}

###

GET {{gateway}}/api/stores/mine
Authorization: Bearer {{token}}

###
