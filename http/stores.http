# ============================================================
# Zenith – Store Service API
# ============================================================
# Direct to store service (8082). After gateway route is added,
# use {{gateway}}/api/stores instead of {{storeService}}.
# ============================================================

@storeService = http://localhost:8082

# ------------------------------------------------------------------------------
# List all stores (Micro-step 1)
# ------------------------------------------------------------------------------
GET {{storeService}}/api/stores

